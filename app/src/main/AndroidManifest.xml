<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:versionCode="2"
    android:versionName="screen-overlay-uvc-camera-1.0">

    <!-- 原项目的相机权限可以保留，但这个屏幕识别版本不再依赖相机 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.external" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <application android:label="@string/app_name">
        <activity
            android:name="com.tencent.nanodetncnn.MainActivity"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.tencent.nanodetncnn.UsbCameraDetectActivity"
            android:label="USB摄像头识别"
            android:screenOrientation="landscape"
            android:exported="false" />

        <activity
            android:name="com.tencent.nanodetncnn.UvcCameraDetectActivity"
            android:label="UVC摄像头识别"
            android:screenOrientation="landscape"
            android:exported="false" />

        <service
            android:name="com.tencent.nanodetncnn.ScreenDetectService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />
    </application>
</manifest>
