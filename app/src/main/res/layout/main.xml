<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:padding="12dp"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="NanoDet 识别：屏幕录制 / UVC摄像头"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content">

        <Spinner
            android:id="@+id/spinnerModel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawSelectorOnTop="true"
            android:entries="@array/model_array" />

        <Spinner
            android:id="@+id/spinnerCPUGPU"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawSelectorOnTop="true"
            android:entries="@array/cpugpu_array" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonStartScreenDetect"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="开始识别屏幕画面" />

    <Button
        android:id="@+id/buttonStopScreenDetect"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="停止识别" />


    <Button
        android:id="@+id/buttonStartUvcCameraDetect"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="UVC摄像头识别（真UVC直连）" />

    <Button
        android:id="@+id/buttonStartUsbCameraDetect"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:text="USB摄像头识别（Camera2）" />

    <TextView
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingTop="12dp"
        android:text="首次运行需要允许：1. 显示在其他应用上层；2. 系统录屏授权。\n识别框会以透明悬浮窗形式画在当前屏幕上。32 位设备建议选择 CPU 和 ELite0_320。" />
</LinearLayout>
